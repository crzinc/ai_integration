# Telegram Bot Token from @BotFather
TELEGRAM_BOT_TOKEN=your_token_here

# OpenRouter API key (free tier available at openrouter.ai)
OPENROUTER_API_KEY=your_key_here
OPENROUTER_MODEL=qwen/qwen-2-7b-instruct:free

# Database
DATABASE_URL=sqlite+aiosqlite:///./classifier.db

# Logging
LOG_LEVEL=INFO

# Routing - Telegram chat IDs for each department
ROUTING_SALES_CHAT_ID=0
ROUTING_SUPPORT_CHAT_ID=0
ROUTING_TECH_CHAT_ID=0
ROUTING_BILLING_CHAT_ID=0
ROUTING_MANAGEMENT_CHAT_ID=0

# Auto-response
AUTO_RESPONSE_ENABLED=true
CONFIDENCE_THRESHOLD=0.7

# Admin notifications
ADMIN_CHAT_ID=0

# Dashboard password
DASHBOARD_PASSWORD=admin123
